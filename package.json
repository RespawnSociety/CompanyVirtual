{
  "name": "virtual-company",
  "version": "0.0.0",
  "private": true,
  "description": "Virtual Company Platform — platform agent AI yang divisualkan sebagai kantor 2D. Lihat virtual-company-platform-plan.md.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --build",
    "typecheck:clean": "tsc --build --clean",
    "lint": "eslint .",
    "pretest": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "prespike:router": "npm run build",
    "spike:router": "tsx infra/scripts/spike-router.ts",
    "prespike:loop": "npm run build",
    "spike:loop": "tsx infra/scripts/spike-loop.ts",
    "prespike:wa": "npm run build",
    "spike:wa": "tsx infra/scripts/spike-wa.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.5",
    "eslint": "^9.17.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.19.1",
    "vitest": "^3.0.2"
  }
}
