# ============================================================
# Virtual Company Platform — contoh environment.
# Salin ke `.env` (DIABAIKAN git) dan isi nilai asli.
# JANGAN commit `.env`. Lihat plan §8 (Secrets via Vault).
# ============================================================

# ---- 9Router (gateway LLM tunggal) ----
# Endpoint OpenAI-compatible. Default sesuai plan §2.
NINEROUTER_BASE_URL=http://localhost:20128/v1
# Sebagian deployment 9Router butuh API key; kosongkan bila lokal tanpa auth.
NINEROUTER_API_KEY=
# Model per tier (fallback 3-tier: subscription -> cheap -> free).
# Terbukti jalan + dukung tool calling (lihat docs/SPIKES.md). Cek `GET /v1/models` utk daftar.
NINEROUTER_MODEL_SUBSCRIPTION=kr/claude-sonnet-4.5
NINEROUTER_MODEL_CHEAP=kr/claude-haiku-4.5
NINEROUTER_MODEL_FREE=

# ---- Agent / web_search skill ----
# Mode mock dipakai saat spike tanpa layanan eksternal.
# Saat ini HANYA "mock" yang didukung; nilai lain → server gagal start (provider nyata = Phase 4+).
WEB_SEARCH_MODE=mock
# Bila pakai provider nyata nanti (mis. SerpAPI/Brave), taruh kuncinya di sini.
WEB_SEARCH_API_KEY=

# ---- WhatsApp (comms) ----
# Adapter: "mock" (uji lokal), "cloud" (Meta WhatsApp Cloud API), "baileys" (proto, belum diimplementasi).
WA_ADAPTER=mock
# Daftar nomor owner/whitelist yang boleh memberi arahan & approval (pisahkan koma, format E.164).
WA_OWNER_NUMBERS=+6281234567890
# Cloud API (hanya bila WA_ADAPTER=cloud)
WA_CLOUD_PHONE_NUMBER_ID=
WA_CLOUD_ACCESS_TOKEN=
WA_CLOUD_VERIFY_TOKEN=change-me-webhook-verify-token
WA_CLOUD_GRAPH_VERSION=v21.0

# ---- Server ----
SERVER_HOST=127.0.0.1
SERVER_PORT=8787
# Path file SQLite Configuration layer (Phase 1). ":memory:" = non-persisten (uji).
DB_PATH=data/vc.db
# Origin yang diizinkan CORS untuk REST/realtime (default "*" untuk dev lokal).
# Di dev, web (Vite :5173) sudah mem-proxy /api & /socket.io → CORS tak diperlukan.
# Di produksi/hosting non-lokal: KETATKAN ke origin spesifik (mis. https://app.contoh.com).
WEB_ORIGIN=*
# Token bearer untuk melindungi REST /api/* (CR-101). Kosong = /api/* TERBUKA (hanya dev lokal,
# bind 127.0.0.1). Bila SERVER_HOST non-loopback, token WAJIB diisi atau server menolak start.
# Klien kirim header: `Authorization: Bearer <token>`.
API_AUTH_TOKEN=
