# ============================================================
# Virtual Company Platform — contoh environment.
# Salin ke `.env` (DIABAIKAN git) dan isi nilai asli.
# JANGAN commit `.env`. Lihat plan §8 (Secrets via Vault).
# ============================================================

# ---- 9Router (gateway LLM tunggal) ----
# Endpoint OpenAI-compatible. Default sesuai plan §2.
NINEROUTER_BASE_URL=http://localhost:20128/v1
# Sebagian deployment 9Router butuh API key; kosongkan bila lokal tanpa auth.
NINEROUTER_API_KEY=
# Model per tier (fallback 3-tier: subscription -> cheap -> free).
# Terbukti jalan + dukung tool calling (lihat docs/SPIKES.md). Cek `GET /v1/models` utk daftar.
NINEROUTER_MODEL_SUBSCRIPTION=kr/claude-sonnet-4.5
NINEROUTER_MODEL_CHEAP=kr/claude-haiku-4.5
NINEROUTER_MODEL_FREE=
# Phase 5.5 — "cache routing tier": setelah sebuah tier GAGAL, lewati selama N ms (hemat panggilan
# ke tier yang sedang mati). Default 30000. 0 = nonaktif (selalu coba urutan penuh).
NINEROUTER_TIER_COOLDOWN_MS=30000

# ---- Agent / web_search skill ----
# Mode mock dipakai saat spike tanpa layanan eksternal.
# Saat ini HANYA "mock" yang didukung; nilai lain → server gagal start (provider nyata = Phase 4+).
WEB_SEARCH_MODE=mock
# Bila pakai provider nyata nanti (mis. SerpAPI/Brave), taruh kuncinya di sini.
WEB_SEARCH_API_KEY=

# ---- WhatsApp (comms) ----
# Adapter: "mock" (uji lokal), "cloud" (Meta WhatsApp Cloud API), "baileys" (proto, belum diimplementasi).
WA_ADAPTER=mock
# Daftar nomor owner/whitelist yang boleh memberi arahan & approval (pisahkan koma, format E.164).
WA_OWNER_NUMBERS=+6281234567890
# Cloud API (hanya bila WA_ADAPTER=cloud)
WA_CLOUD_PHONE_NUMBER_ID=
WA_CLOUD_ACCESS_TOKEN=
WA_CLOUD_VERIFY_TOKEN=change-me-webhook-verify-token
WA_CLOUD_GRAPH_VERSION=v21.0

# ---- Database (MySQL/MariaDB — XAMPP) ----
# Persistensi Configuration layer + runtime (Phase 2). Driver mysql2 (pure-JS, tanpa native build).
# Buat database dulu: `CREATE DATABASE virtual_company CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;`
# Default cocok dengan XAMPP (root tanpa password). Lihat docs/RUNBOOK.md.
DB_MYSQL_HOST=127.0.0.1
DB_MYSQL_PORT=3306
DB_MYSQL_USER=root
DB_MYSQL_PASSWORD=
DB_MYSQL_DATABASE=virtual_company
# Database khusus test (dibuat otomatis bila belum ada). Dipakai `npm test`.
DB_MYSQL_TEST_DATABASE=virtual_company_test

# ---- Server ----
SERVER_HOST=127.0.0.1
SERVER_PORT=8787
# Origin yang diizinkan CORS untuk REST/realtime (default "*" untuk dev lokal).
# Di dev, web (Vite :5173) sudah mem-proxy /api & /socket.io → CORS tak diperlukan.
# Di produksi/hosting non-lokal: KETATKAN ke origin spesifik (mis. https://app.contoh.com).
WEB_ORIGIN=*
# Token bearer untuk melindungi REST /api/* (CR-101). Kosong = /api/* TERBUKA (hanya dev lokal,
# bind 127.0.0.1). Bila SERVER_HOST non-loopback, token WAJIB diisi atau server menolak start.
# Klien kirim header: `Authorization: Bearer <token>`. Realtime socket juga divalidasi (BUG-108).
API_AUTH_TOKEN=

# ---- Web (FACE) auth — Phase 4 (BUG-107/108) ----
# Token build-time yang DI-EMBED ke bundle web agar REST + socket kirim bearer saat API_AUTH_TOKEN aktif.
# Set SAMA dengan API_AUTH_TOKEN. CATATAN: token ter-embed di bundle (bukan rahasia per-user) →
# cocok utk dev/token bersama; untuk hosting publik pakai reverse-proxy/login (lihat docs/RUNBOOK.md).
VITE_API_AUTH_TOKEN=

# ============================================================
# Phase 4 — Aksi Eksternal + Keamanan
# ============================================================

# ---- Credential Vault (4.1) — brankas terenkripsi ----
# Mode: "file" (default, AES-256-GCM + fallback env) | "env" (baca dari env saja) | "noop" (kosong).
VAULT_MODE=file
# Master key untuk mode file (passphrase bebas; di-scrypt jadi kunci 32-byte). WAJIB diisi mode file.
# JANGAN commit. Tanpa ini, mode file turun ke env-only (warning).
VAULT_MASTER_KEY=
# Lokasi file vault terenkripsi (default data/vault.enc; folder data/ sudah di-.gitignore).
VAULT_PATH=data/vault.enc
# Kelola secret: `npm run vault -- set <key>` (nilai via STDIN), `... has|del|list`.
# Contoh kredensial sosmed (mode env / fallback): VAULT_<KEY_UPPERCASE_NONALNUM→_>
# VAULT_INSTAGRAM_USERNAME=...   (logical key: instagram.username)
# VAULT_INSTAGRAM_PASSWORD=...   (logical key: instagram.password)
# VAULT_TWITTER_USERNAME=...     VAULT_TWITTER_PASSWORD=...

# ---- Skill sosial / publish (4.2) ----
# Provider posting: "mock" (default, dry-run deterministik — tak benar-benar terbit) |
# "playwright" (otomasi browser NYATA; butuh `npm i -D playwright` + `npx playwright install chromium`
# + kredensial di Vault). Semua publish tetap approval-gated + guardrail (4.4).
POST_PROVIDER=mock
# Jalankan browser tanpa UI (true) atau terlihat (false) saat POST_PROVIDER=playwright.
POST_PLAYWRIGHT_HEADLESS=true

# ============================================================
# Phase 5 — Generalisasi Platform (KPI biaya + optimasi)
# ============================================================

# ---- Throttle panggilan LLM (5.5) ----
# Batas panggilan chat 9Router bersamaan (lindungi router lokal). Default 4. 0 = tak dibatasi.
LLM_MAX_CONCURRENCY=4
# Jarak minimum (ms) antar-AWAL panggilan (rate-limit halus). Default 0 (nonaktif).
LLM_MIN_INTERVAL_MS=0
# Catatan: LLM_MAX_CONCURRENCY=0 DAN LLM_MIN_INTERVAL_MS=0 → tanpa throttle sama sekali.

# ---- Tarif estimasi biaya untuk KPI dashboard (5.4) ----
# Biaya = token NYATA × tarif per-1.000-token per tier. subscription biasanya langganan flat → 0.
# Token tetap ditampilkan apa adanya; biaya rupiah hanya perkiraan. Ubah sesuai tarif aslimu.
COST_CURRENCY=IDR
COST_PER_1K_SUBSCRIPTION=0
COST_PER_1K_CHEAP=50
COST_PER_1K_FREE=0
